{
	"name": "jmrad-theme",
	"$schema": "vscode://schemas/color-theme",
	"type": "dark",
	"colors": {
	// ===== Editor =====
	"editor.background": "#1E1E1E",
	"editor.foreground": "#D4D4D4",

	"editor.selectionBackground": "#8C6EFF33",
	"editor.selectionHighlightBackground": "#9C7CFF44",

	"editorBracketMatch.background": "#00000000",
	"editorBracketMatch.border": "#3b2881",

	"editorIndentGuide.background": "#404040",
	"editorIndentGuide.activeBackground": "#707070",

	"menu.separatorBackground": "#333333",  // separator line

	
	"editorCursor.foreground": "#82AAFF",
	"button.background": "#007ACC",

	// ===== Workbench (Modern UI) =====
	"sideBar.background": "#181818",
	"sideBar.foreground": "#CCCCCC",
	"sideBarTitle.foreground": "#BBBBBB",
	"sideBar.border": "#00000000",
	// Selection
	"list.activeSelectionBackground": "default",  // lighter translucent purple
	"focusBorder": "#333",                        // medium purple for outlines/focus
	"list.inactiveSelectionBackground": "#ffffff05",

	// Hover
	"list.hoverBackground": "#ffffff08",

	// Section headers (Outline / Timeline titles)
	"sideBarSectionHeader.background": "#181818",
	"sideBarSectionHeader.border": "#252525",
	
	"activityBar.background": "#141414",
	"activityBar.foreground": "#BBBBBB",
	"activityBar.inactiveForeground": "#666666",
	"activityBar.border": "#252525",
	// "activityBar.activeBorder": "#8C6EFF",
	"activityBar.activeBorder": "#007ACC",
	"activityBarBadge.background": "#007ACC",

	"panel.background": "#181818",
	"panel.border": "#00000000",

	"titleBar.activeBackground": "#121212",
	"titleBar.inactiveBackground": "#121212",

	"statusBar.background": "#181818",
	"statusBar.foreground": "#CCCCCC",
	"statusBar.border": "#252525",
	"statusBarItem.remoteForeground": "#FFFFFF",
	"statusBarItem.remoteBackground": "#16825D",

	// ===== Tabs =====
	"tab.activeBackground": "#1E1E1E",
	"tab.inactiveBackground": "#181818",
	"tab.border": "#00000000",

	// ===== Inputs & Menus =====
	"menu.background": "#1C1C1C",
	"menu.foreground": "#CCCCCC",
	"input.placeholderForeground": "#A6A6A6",
	"settings.textInputBackground": "#292929",
	"settings.numberInputBackground": "#292929",

	// ===== Misc =====
	"list.dropBackground": "#383B3D",
	"editorGroup.border": "#00000000",

	// ===== Scrollbar =====
	"scrollbarSlider.background": "#ffffff10",
	"scrollbarSlider.hoverBackground": "#ffffff20",
	"scrollbarSlider.activeBackground": "#ffffff30"
	},
		"tokenColors": [
		{
			"scope": ["comment"],
			"settings": { 
				"foreground": "#a19b8f",
			 	"fontStyle": "italic" 
			}
		},
		// Normal string literals (green)
		{
		"scope": ["string.quoted.double", "string.quoted.single", "string.constant"],
		"settings": { "foreground": "#8DDC8A" }  // soft green
		},

		// Preprocessor includes or special quoted other (blue)
		{
		"scope": ["string.quoted.other", "string support", "string keyword"],
		"settings": { "foreground": "#9DCDF5" }  // VS Code blue
		},
		
		{
			"scope": ["constant.language"],
			"settings": { "foreground": "#0086b3" }
		},
		{
			"scope": ["constant.other", "support.constant"],
			"settings": { "foreground": "#66B5F6" }
		},
		{
			"scope": ["variable", "variable.other", "variable.parameter", "variable.other.exported.go"],
			"settings": { "foreground": "#A8DEFF" }
		},
		{
			"scope": ["keyword", "keyword.operator.arithmetic.shell", "storage", "support.type.return", "support.type.receiver"],
			"settings": { "foreground": "#eb7e81" }
		},
		{
			"scope": ["entity.name.class", "entity.name.type.class", "entity.name.type.interface", "entity.section.ini", "entity.name.section"],
			"settings": { "foreground": "#bb97e7" }
		},
		{
			"scope": ["entity.name.function", "meta.function-call.generic", "meta.function-call.object", "meta.function-call.static", "meta.function-call.ts"],
			"settings": { "foreground": "#bb97e7" }
		},
		{
			"scope": ["entity.name.tag", "entity.tag.apacheconf"],
			"settings": { "foreground": "#66B5F6" }
		},
		{
			"scope": ["entity.other.attribute-name", "entity.other.pseudo-element"],
			"settings": { "foreground": "#bb97e7" }
		},
		{
			"scope": ["support.type", "support.other.namespace", "support.class", "source.js support.type", "support.constant.color"],
			"settings": { "foreground": "#66B5F6" }
		},
		{
			"scope": ["constant.numeric", "constant.character.entity"],
			"settings": { "foreground": "#66B5F6" }
		},
		{
			"scope": ["invalid"],
			"settings": { "foreground": "#fafbfc", "background": "#DC5148" }
		},
		{
			"scope": ["meta.property-name.css", "meta.property-value.css support", "meta.property-value.css support.constant", "meta.property-value.css"],
			"settings": { "foreground": "#66B5F6" }
		},
		{
			"scope": ["meta.property-value.css punctuation"],
			"settings": { "foreground": "#ffffff" }
		}
	],
	"uuid": "96D817F0-8536-11E4-B4A9-0800200C9A66"
}